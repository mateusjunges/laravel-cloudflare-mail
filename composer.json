{
    "name": "mateusjunges/laravel-cloudflare-mail",
    "description": "Cloudflare Email Service transport for Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "mail",
        "mailer",
        "transport",
        "cloudflare",
        "email",
        "cloudflare-email-service"
    ],
    "homepage": "https://github.com/mateusjunges/laravel-cloudflare-mail",
    "authors": [
        {
            "name": "Mateus Junges",
            "email": "mateus@junges.dev",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/mateusjunges/laravel-cloudflare-mail/issues",
        "source": "https://github.com/mateusjunges/laravel-cloudflare-mail"
    },
    "require": {
        "php": "^8.4",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/mail": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "symfony/mailer": "^7.2|^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.20",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.0"
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse",
        "phpstan:ci": "vendor/bin/phpstan analyse --no-progress",
        "pint": "vendor/bin/pint",
        "pint:test": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector process",
        "rector:dry-run": "vendor/bin/rector process --dry-run",
        "cs": [
            "@rector",
            "@pint",
            "@phpstan"
        ],
        "test": "vendor/bin/pest"
    },
    "autoload": {
        "psr-4": {
            "Junges\\CloudflareMail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Junges\\CloudflareMail\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Junges\\CloudflareMail\\Providers\\CloudflareMailServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
